<Application x:Class="PawnBrokerERP.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:PawnBrokerERP.Helpers">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/ModernTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <helpers:StringToVisibilityConverter x:Key="StringToVisibility"/>
            <helpers:InvertBoolConverter x:Key="InvertBool"/>
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <helpers:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
