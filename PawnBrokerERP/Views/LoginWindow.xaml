<Window x:Class="PawnBrokerERP.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PawnBroker ERP — Login"
        Height="600" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="16"
            BorderBrush="{StaticResource BorderBrush2}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0"
                    Background="{StaticResource SidebarBrush}"
                    MouseDown="TitleBar_MouseDown">
                <Grid>
                    <TextBlock Text="PawnBroker ERP" Foreground="{StaticResource AccentGoldBrush}"
                               FontWeight="SemiBold" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Content="✕" Click="CloseButton_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,12,0" Width="24" Height="24"
                            Background="Transparent" Foreground="{StaticResource TextSubBrush}"
                            BorderThickness="0" Cursor="Hand" FontSize="13"/>
                </Grid>
            </Border>

            <!-- Login Form -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="48,0">

                <Border Width="72" Height="72" CornerRadius="36"
                        Background="{StaticResource AccentGoldBrush}"
                        HorizontalAlignment="Center" Margin="0,0,0,24">
                    <TextBlock Text="₹" FontSize="36" FontWeight="Bold"
                               Foreground="#0F0F1A"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Welcome Back" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextWhiteBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Sign in to manage your pawn shop"
                           FontSize="13" Foreground="{StaticResource TextSubBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,32"/>

                <TextBlock Text="PHONE NUMBER" Style="{StaticResource FieldLabel}"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="10" Margin="0,0,0,16"/>

                <TextBlock Text="PASSWORD" Style="{StaticResource FieldLabel}"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,8"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="12" TextWrapping="Wrap"
                           Margin="0,4,0,12"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                <Button Content="LOGIN"
                        Style="{StaticResource GoldButton}"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                        Margin="0,0,0,24"/>

                <!-- Busy Indicator -->
                <TextBlock Text="Authenticating..."
                           Foreground="{StaticResource TextSubBrush}"
                           HorizontalAlignment="Center" FontSize="12"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>
