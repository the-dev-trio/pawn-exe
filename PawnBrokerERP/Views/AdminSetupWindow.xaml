<Window x:Class="PawnBrokerERP.Views.AdminSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PawnBroker ERP — First Time Setup"
        Height="680" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="16"
            BorderBrush="{StaticResource AccentGoldBrush}"
            BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="16,16,0,0"
                    Background="{StaticResource SidebarBrush}"
                    MouseDown="TitleBar_MouseDown">
                <TextBlock Text="⚙  First Time Setup — Admin Only"
                           Foreground="{StaticResource AccentGoldBrush}"
                           FontWeight="SemiBold" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="40,24">

                    <TextBlock Text="Initialize Shop" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextWhiteBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="Enter admin credentials to set up this USB drive"
                               FontSize="13" Foreground="{StaticResource TextSubBrush}"
                               Margin="0,0,0,24"/>

                    <!-- USB Status -->
                    <Border Background="{StaticResource CardBrush}" CornerRadius="8"
                            Padding="12,10" Margin="0,0,0,20"
                            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔌 " FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DetectedSerial}"
                                       Foreground="{StaticResource AccentGoldBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="ADMIN TOKEN" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="AdminTokenBox"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,16"
                                 PasswordChanged="AdminTokenBox_PasswordChanged"/>

                    <TextBlock Text="SHOP NAME" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding ShopName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="CLIENT PHONE NUMBER (10 DIGITS)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="10" Margin="0,0,0,16"/>

                    <TextBlock Text="CLIENT PASSWORD" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,16"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <TextBlock Text="CONFIRM PASSWORD" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Style="{StaticResource ModernPasswordBox}"
                                 Margin="0,0,0,8"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource ErrorBrush}"
                               FontSize="12" TextWrapping="Wrap"
                               Margin="0,4,0,8"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="12" TextWrapping="Wrap"
                               Margin="0,0,0,8"
                               Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibility}}"/>

                    <Button Content="INITIALIZE SHOP"
                            Style="{StaticResource GoldButton}"
                            Command="{Binding InitializeCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                            Margin="0,8,0,24"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
