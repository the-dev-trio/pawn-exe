<UserControl x:Class="PawnBrokerERP.Views.Pages.PartPaymentPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{StaticResource BackgroundBrush}">
        <StackPanel Margin="32,28" MaxWidth="640">

            <TextBlock Text="Part Payment" Style="{StaticResource PageTitle}"/>

            <!-- Search -->
            <Border Style="{StaticResource MetricCard}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="SEARCH TICKET" Style="{StaticResource FieldLabel}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}"
                                 Text="{Binding TicketSearch, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="SEARCH" Style="{StaticResource GoldButton}"
                                Command="{Binding SearchCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                       Margin="0,0,0,12"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            <Border Background="#33279227" CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"/>
            </Border>

            <!-- Details Panel -->
            <Border Style="{StaticResource MetricCard}"
                    Visibility="{Binding PledgeFound, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="PLEDGE SUMMARY" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CUSTOMER" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding CustomerName}" Foreground="{StaticResource TextWhiteBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="LOAN AMOUNT" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding LoanAmount, StringFormat='₹{0:N2}'}" Foreground="{StaticResource TextWhiteBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ALREADY PAID" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding AlreadyPaid, StringFormat='₹{0:N2}'}" Foreground="{StaticResource SuccessBrush}"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="{StaticResource BorderBrush2}" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="TOTAL OUTSTANDING" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalDue, StringFormat='₹{0:N2}'}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentGoldBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <TextBlock Text="PAYMENT AMOUNT (₹)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,16"/>

                    <Button Content="RECORD PART PAYMENT" Style="{StaticResource GoldButton}"
                            Command="{Binding RecordPaymentCommand}" Height="48" FontSize="14"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
