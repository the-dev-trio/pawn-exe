<UserControl x:Class="PawnBrokerERP.Views.Pages.RedeemPledgePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{StaticResource BackgroundBrush}">
        <StackPanel Margin="32,28" MaxWidth="680">

            <TextBlock Text="Redeem Pledge" Style="{StaticResource PageTitle}"/>

            <!-- Search -->
            <Border Style="{StaticResource MetricCard}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="SEARCH BY TICKET NUMBER" Style="{StaticResource FieldLabel}"/>
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}"
                                 Text="{Binding TicketSearch, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2" Content="SEARCH" Style="{StaticResource GoldButton}"
                                Command="{Binding SearchCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                       FontSize="13" Margin="0,0,0,12"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

            <!-- Success -->
            <Border Background="#33279227" CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}"
                           FontWeight="SemiBold"/>
            </Border>

            <!-- Pledge Details Panel -->
            <Border Style="{StaticResource MetricCard}"
                    Visibility="{Binding PledgeFound, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="PLEDGE DETAILS" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="CUSTOMER" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding CustomerName}" Foreground="{StaticResource TextWhiteBrush}" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="PLEDGE DATE" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PledgeDate}" Foreground="{StaticResource TextWhiteBrush}" FontSize="15"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="ITEM" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding ItemDescription}" Foreground="{StaticResource TextWhiteBrush}" FontSize="15"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="DAYS ELAPSED" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding DaysElapsed, StringFormat='{}{0} days'}" Foreground="{StaticResource WarningBrush}" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="LOAN AMOUNT" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding LoanAmount, StringFormat='₹{0:N2}'}" Foreground="{StaticResource TextWhiteBrush}" FontSize="15"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                            <TextBlock Text="INTEREST ACCRUED" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding InterestAccrued, StringFormat='₹{0:N2}'}" Foreground="{StaticResource WarningBrush}" FontSize="15"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,0">
                            <TextBlock Text="PART PAID" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding PartPaid, StringFormat='₹{0:N2}'}" Foreground="{StaticResource SuccessBrush}" FontSize="15"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="{StaticResource BorderBrush2}" Margin="0,8,0,16"/>

                    <Grid>
                        <TextBlock Text="TOTAL DUE" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalDue, StringFormat='₹{0:N2}'}"
                                   Foreground="{StaticResource AccentGoldBrush}"
                                   FontSize="32" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>

                    <Button Content="COLLECT PAYMENT &amp; REDEEM"
                            Style="{StaticResource GoldButton}"
                            Command="{Binding RedeemCommand}"
                            Height="52" FontSize="15" Margin="0,16,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
