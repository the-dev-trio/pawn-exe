<UserControl x:Class="PawnBrokerERP.Views.Pages.NewPledgePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Background="{StaticResource BackgroundBrush}">
        <StackPanel Margin="32,28" MaxWidth="720">

            <TextBlock Text="New Pledge" Style="{StaticResource PageTitle}"/>

            <!-- Customer Section -->
            <Border Style="{StaticResource MetricCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="CUSTOMER INFORMATION" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CUSTOMER NAME" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="PHONE NUMBER" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" MaxLength="10"
                                     Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="AADHAAR NUMBER" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource ModernTextBox}" MaxLength="12"
                                     Text="{Binding AadhaarNumber, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ADDRESS" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding CustomerAddress, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Item Section -->
            <Border Style="{StaticResource MetricCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="ITEM DETAILS" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,16"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="ITEM DESCRIPTION" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource ModernTextBox}"
                                 Text="{Binding ItemDescription, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CATEGORY" Style="{StaticResource FieldLabel}"/>
                            <ComboBox Style="{StaticResource ModernComboBox}"
                                      ItemsSource="{Binding ItemCategories}"
                                      SelectedItem="{Binding ItemCategory}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="WEIGHT (GRAMS)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding WeightGrams, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="PURITY (%)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding PurityPercent, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Loan Section -->
            <Border Style="{StaticResource MetricCard}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="LOAN DETAILS" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource AccentGoldBrush}" Margin="0,0,0,16"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="LOAN AMOUNT (₹)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding LoanAmount, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="MONTHLY INTEREST RATE (%)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Text="{Binding InterestRate, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Messages -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                       FontSize="13" TextWrapping="Wrap" Margin="0,0,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
            <Border Background="#33279227" CornerRadius="6" Padding="12,10" Margin="0,0,0,8"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}"
                           FontSize="13" FontWeight="SemiBold"/>
            </Border>

            <Button Content="CREATE PLEDGE &amp; GENERATE TICKET"
                    Style="{StaticResource GoldButton}"
                    Command="{Binding CreatePledgeCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                    Height="52" FontSize="15"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
